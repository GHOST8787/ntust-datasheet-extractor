# ============================================================
# Backend 選擇(必填)
# ============================================================
# 可選值: ollama / azure_gpt4o / azure_llama / azure_mistral
BACKEND=ollama

# PDF 抽取方法(實驗自變數)
# 可選值: pdfplumber / fitz / camelot
PDF_EXTRACTOR=pdfplumber

# 共用參數
LLM_TEMPERATURE=0


# ============================================================
# 本地 Ollama(BACKEND=ollama 時用)
# ============================================================
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_NUM_CTX=16384


# ============================================================
# Microsoft Foundry V1 統一 API(GPT-4o + Llama + Mistral 共用)
# ============================================================
# Foundry V1 的所有 deployment 共用 endpoint + key,只差 deployment name。
# 從 Foundry「详细信息」「目标 URI」拿到,把尾端 /responses 等路徑去掉。
# 例如 GPT-4o 顯示的 URI:
#   https://xxx.services.ai.azure.com/api/projects/yyy/openai/v1/responses
# ENDPOINT 填(去掉 /responses):
#   https://xxx.services.ai.azure.com/api/projects/yyy/openai/v1
AZURE_FOUNDRY_ENDPOINT=https://YOUR_PROJECT_RESOURCE.services.ai.azure.com/api/projects/YOUR_PROJECT/openai/v1
AZURE_FOUNDRY_KEY=

# 各模型的 deployment name(從 Foundry 部署時自取的名字)
AZURE_GPT4O_DEPLOYMENT=gpt-4o
AZURE_LLAMA_DEPLOYMENT=Llama-4-Maverick-17B-128E-Instruct-FP8
AZURE_MISTRAL_DEPLOYMENT=
